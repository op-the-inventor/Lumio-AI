<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="200dp"
    android:height="200dp"
    android:viewportWidth="200"
    android:viewportHeight="200">
    <!-- Center Dot (Pulse element) -->
    <path
        android:name="center_dot"
        android:pathData="M100,90 A10,10 0 1,1 100,110 A10,10 0 1,1 100,90"
        android:fillColor="#000000"/>
    
    <!-- Outer Diamond (Scale / Rotate element) -->
    <path
        android:name="outer_diamond"
        android:pathData="M100,20 L180,100 L100,180 L20,100 Z"
        android:strokeColor="#000000"
        android:strokeWidth="6"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>
    
    <!-- Inner Diamond (Path reveal element) -->
    <path
        android:name="inner_diamond"
        android:pathData="M100,50 L150,100 L100,150 L50,100 Z"
        android:strokeColor="#000000"
        android:strokeWidth="6"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"/>
        
    <!-- Connections (Stroke drawing element) -->
    <path
        android:name="conn_top"
        android:pathData="M100,20 L100,50"
        android:strokeColor="#000000"
        android:strokeWidth="6"
        android:strokeLineCap="round"/>
    <path
        android:name="conn_bottom"
        android:pathData="M100,150 L100,180"
        android:strokeColor="#000000"
        android:strokeWidth="6"
        android:strokeLineCap="round"/>
    <path
        android:name="conn_left"
        android:pathData="M20,100 L50,100"
        android:strokeColor="#000000"
        android:strokeWidth="6"
        android:strokeLineCap="round"/>
    <path
        android:name="conn_right"
        android:pathData="M150,100 L180,100"
        android:strokeColor="#000000"
        android:strokeWidth="6"
        android:strokeLineCap="round"/>
</vector>
