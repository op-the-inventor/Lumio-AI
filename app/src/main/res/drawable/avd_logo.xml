<animated-vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:drawable="@drawable/ic_logo">
    
    <target android:name="outer_diamond">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="1200"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="inner_diamond">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:startOffset="300"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="1000"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="conn_top">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:startOffset="800"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="500"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
    
    <target android:name="conn_bottom">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:startOffset="800"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="500"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
    
    <target android:name="conn_left">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:startOffset="800"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="500"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>
    
    <target android:name="conn_right">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="trimPathEnd"
                android:startOffset="800"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="500"
                android:interpolator="@android:interpolator/fast_out_slow_in" />
        </aapt:attr>
    </target>

    <target android:name="center_dot">
        <aapt:attr name="android:animation">
            <objectAnimator
                android:propertyName="fillAlpha"
                android:startOffset="1000"
                android:valueFrom="0"
                android:valueTo="1"
                android:duration="600" />
        </aapt:attr>
    </target>

</animated-vector>
